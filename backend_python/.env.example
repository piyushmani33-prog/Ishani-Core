# TechBuzz AI Agent — Environment Variables
# Copy this to .env and fill in your values

# ── REQUIRED ──────────────────────────────────
# Leave these blank by default. Ishani can run on the built-in local brain
# until you manually enter and save a provider key from Settings.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-5.1-chat-latest
GEMINI_MODEL=gemini-2.0-flash

# ── ADMIN CREDENTIALS ─────────────────────────
MASTER_ACCOUNT_EMAIL=owner@local
MASTER_LOGIN_ID=MasterPiyushMani
MASTER_PASSWORD_SALT=
MASTER_PASSWORD_HASH=
NAUKRI_LAUNCHER_PATH=C:\Users\dell\Downloads\Naukri Launcher Installer.exe

# ── SERVER CONFIG ─────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,https://techbuzzsystems.in,https://www.techbuzzsystems.in

# Port to run the server on
PORT=8000
