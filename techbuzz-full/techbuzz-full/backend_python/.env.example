# TechBuzz AI Agent — Environment Variables
# Copy this to .env and fill in your values

# ── AI PROVIDERS ──────────────────────────────
# Leave blank to use the built-in fallback brain.
# Add any one key to unlock the corresponding AI provider.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional model overrides (leave blank for defaults)
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-5.1-chat-latest
GEMINI_MODEL=gemini-2.0-flash

# Local Ollama endpoint (if running locally)
OLLAMA_HOST=http://localhost:11434

# ── ADMIN CREDENTIALS ─────────────────────────
# Set these before first launch to create the master account.
# Generate salt/hash with: python -c "import hashlib,os; s=os.urandom(16).hex(); print('SALT:', s); print('HASH:', hashlib.sha256((s+'yourpassword').encode()).hexdigest())"
MASTER_ACCOUNT_EMAIL=owner@local
MASTER_LOGIN_ID=MasterAdmin
MASTER_PASSWORD_SALT=
MASTER_PASSWORD_HASH=

# ── SECURITY ──────────────────────────────────
# Session secret — used to sign session cookies.
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SESSION_SECRET=

# ── SERVER CONFIG ─────────────────────────────
# Port to run the server on
PORT=8000

# Host to bind to (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
HOST=0.0.0.0

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Comma-separated list of allowed frontend origins (CORS)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ── RATE LIMITING ─────────────────────────────
# Maximum requests per IP per minute
RATE_LIMIT_PER_MINUTE=60

# ── DATABASE ──────────────────────────────────
# Default: SQLite in the data/ directory (suitable for development/single-user)
# For production with multiple users, use PostgreSQL: postgresql://user:pass@host/db
DATABASE_URL=sqlite:///data/techbuzz.db

# ── MODE FLAGS ────────────────────────────────
# Set DEMO_MODE=true to disable write/delete operations (safe for public demos)
DEMO_MODE=false

# Set ADMIN_ROUTES_ENABLED=false to hide admin endpoints from non-master users
ADMIN_ROUTES_ENABLED=true
