# Production environment template for TechBuzz AI / Ishani-Core
# Copy this file to .env.production and fill in all values before deploying.
# NEVER commit the filled-in .env.production file to version control.

# ── AI PROVIDERS ──────────────────────────────
# At least one provider is recommended for full AI functionality.
# Leave blank to use the built-in fallback brain only.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── ADMIN CREDENTIALS ─────────────────────────
# The master account email (used for login).
MASTER_ACCOUNT_EMAIL=

# Generate a salt/hash pair with (uses PBKDF2-HMAC-SHA256 for production strength):
#   python -c "
#   import hashlib, os, getpass
#   salt = os.urandom(16).hex()
#   pwd = getpass.getpass('Password: ')
#   hash_ = hashlib.pbkdf2_hmac('sha256', pwd.encode(), salt.encode(), 260000).hex()
#   print('MASTER_PASSWORD_SALT=' + salt)
#   print('MASTER_PASSWORD_HASH=' + hash_)
#   "
MASTER_PASSWORD_SALT=
MASTER_PASSWORD_HASH=

# ── SECURITY ──────────────────────────────────
# Session secret — signs session cookies. Must be long and random.
# Generate with: python -c "import os; print(os.urandom(32).hex())"
SESSION_SECRET=

# Comma-separated list of allowed frontend origins (no trailing slashes).
# Example: https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# ── MODE FLAGS ────────────────────────────────
# Set DEMO_MODE=true for public demo instances (disables write/delete ops).
DEMO_MODE=false

# Set to false to hide admin endpoints from non-master users.
ADMIN_ROUTES_ENABLED=true

# ── SERVER CONFIG ─────────────────────────────
PORT=8000
LOG_LEVEL=WARNING
RATE_LIMIT_PER_MINUTE=30

# ── DATABASE ──────────────────────────────────
# Default: SQLite (suitable for single-user / low-traffic).
# For production with multiple users: postgresql://user:pass@host/dbname
DATABASE_URL=sqlite:///data/techbuzz.db
